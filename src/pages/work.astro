---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title="Proyectos | Lucía García"
	description="Explora los proyectos de diseño de Lucía García"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Proyectos"
				tagline="Explora mis proyectos de diseño. Cada uno representa mi dedicación, creatividad y el proceso de aprendizaje continuo en mi camino como diseñadora."
				align="start"
			/>
			<Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
